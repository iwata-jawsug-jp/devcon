{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite-ssg build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lhci": "lhci autorun",
    "check:bundle-budget": "node scripts/check-bundle-budget.mjs",
    "gen-types": "openapi-typescript http://localhost:8000/openapi.json -o src/api/schema.ts",
    "design:lint": "designmd lint ../../docs/frontend-design.md",
    "design:gen-theme": "node scripts/gen-design-tokens.mjs"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.101.4",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^4.0.2",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@google/design.md": "^0.3.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.47.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^25.9.5",
    "@unhead/vue": "^2.1.16",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.4.0",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vite-ssg": "^28.3.0",
    "vite-ssg-sitemap": "^0.10.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.8"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "uuid": "^11.1.1",
    "js-yaml": "^4.3.0"
  }
}
