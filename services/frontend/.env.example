# Copy to `.env` and adjust. Only VITE_-prefixed, non-secret vars are exposed
# to the client bundle. Never put secrets here.

# Base path for API requests. In dev, Vite proxies `/api` -> http://localhost:8000.
VITE_API_BASE=/api
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_REGION=ap-northeast-1
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
