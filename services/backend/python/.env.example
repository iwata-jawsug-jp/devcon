# Copy to .env and adjust. All vars are prefixed with API_.
API_ENVIRONMENT=dev
API_APP_NAME=api
API_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app

# Component-based DB config (alternative to API_DATABASE_URL above — set
# API_DB_HOST to assemble the connection from these instead, e.g. when ECS
# injects RDS outputs + the RDS-managed secret).
API_DB_HOST=
API_DB_PORT=5432
API_DB_NAME=app
API_DB_USER=app
API_DB_PASSWORD=

API_COGNITO_USER_POOL_ID=
API_COGNITO_REGION=ap-northeast-1
API_COGNITO_CLIENT_ID=
API_COGNITO_ISSUER=

# Distributed tracing (OpenTelemetry -> ADOT collector sidecar -> AWS X-Ray, ADR-0007).
API_OTEL_TRACES_ENABLED=false
API_OTEL_EXPORTER_ENDPOINT=http://localhost:4317
API_OTEL_SERVICE_NAME=api
