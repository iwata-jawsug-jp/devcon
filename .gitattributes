# Normalize line endings to LF
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary

# Lock files / generated — collapse in diffs
package-lock.json linguist-generated=true -diff
uv.lock linguist-generated=true -diff
.terraform.lock.hcl linguist-generated=true
