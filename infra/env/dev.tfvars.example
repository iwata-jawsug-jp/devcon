# Copy to env/dev.tfvars (git-ignored) and adjust.
project     = "devcon"
environment = "dev"
aws_region  = "ap-northeast-1"

# Set by the deploy pipeline; leave empty for plan/scaffold.
container_image = ""

# Optional custom domain for the SPA. Empty disables ACM/Route53.
domain_name = ""

# --- Networking ---
vpc_cidr       = "10.0.0.0/16"
vpce_single_az = true

# --- Database (RDS PostgreSQL) — cheap, disposable dev settings ---
db_engine_version        = "16"
db_instance_class        = "db.t4g.micro"
db_allocated_storage     = 20
db_max_allocated_storage = 100
db_name                  = "app"
db_username              = "app"
db_backup_retention      = 7
db_multi_az              = false
db_deletion_protection   = false
db_skip_final_snapshot   = true

# --- ECS Application Auto Scaling — min=max disables scaling (dev doesn't need it) ---
ecs_min_capacity         = 1
ecs_max_capacity         = 1
ecs_cpu_target_value     = 60
ecs_memory_target_value  = 70

# --- Observability — no email in dev by default (avoid alarm-fatigue on a disposable env) ---
alert_email                     = ""
alarm_alb_5xx_threshold         = 5
alarm_alb_latency_seconds       = 1
alarm_ecs_cpu_threshold         = 80
alarm_ecs_memory_threshold      = 80
alarm_rds_cpu_threshold         = 80
alarm_rds_connections_threshold = 80
alarm_rds_free_storage_bytes    = 2000000000

# --- Distributed tracing (ADR-0007) — off by default (extra sidecar cpu/memory,
# VPC endpoint, and IAM only apply when true) ---
otel_traces_enabled = false
