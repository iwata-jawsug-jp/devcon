# Copy to env/dev.tfvars (git-ignored) and adjust.
project     = "devcon"
environment = "dev"
aws_region  = "ap-northeast-1"

# Set by the deploy pipeline; leave empty for plan/scaffold.
container_image = ""

# Optional custom domain for the SPA. Empty disables ACM/Route53.
domain_name = ""

# --- Networking ---
vpc_cidr = "10.0.0.0/16"

# --- Database (RDS PostgreSQL) — cheap, disposable dev settings ---
db_engine_version        = "16"
db_instance_class        = "db.t4g.micro"
db_allocated_storage     = 20
db_max_allocated_storage = 100
db_name                  = "app"
db_username              = "app"
db_backup_retention      = 7
db_multi_az              = false
db_deletion_protection   = false
db_skip_final_snapshot   = true

# --- ECS Application Auto Scaling — min=max disables scaling (dev doesn't need it) ---
ecs_min_capacity         = 1
ecs_max_capacity         = 1
ecs_cpu_target_value     = 60
ecs_memory_target_value  = 70
