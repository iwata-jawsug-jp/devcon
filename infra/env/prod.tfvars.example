# Copy to env/prod.tfvars (git-ignored) and adjust.
project     = "devcon"
environment = "prod"
aws_region  = "ap-northeast-1"

# Set by the deploy pipeline; leave empty for plan/scaffold.
container_image = ""

# Optional custom domain for the SPA. Empty disables ACM/Route53.
domain_name = ""

# --- Networking ---
vpc_cidr = "10.0.0.0/16"

# --- Database (RDS PostgreSQL) — hardened, durable prod settings ---
db_engine_version        = "16"
db_instance_class        = "db.t4g.small"
db_allocated_storage     = 50
db_max_allocated_storage = 200
db_name                  = "app"
db_username              = "app"
db_backup_retention      = 30
db_multi_az              = true
db_deletion_protection   = true
db_skip_final_snapshot   = false

# --- ECS Application Auto Scaling — actually scale in prod (dev default is min=max=1) ---
ecs_min_capacity         = 1
ecs_max_capacity         = 4
ecs_cpu_target_value     = 60
ecs_memory_target_value  = 70
