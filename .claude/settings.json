{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform plan:*)",
      "Bash(terraform init:*)",
      "Bash(tflint:*)",
      "Bash(trivy:*)",
      "Bash(checkov:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(pre-commit:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(aws sts get-caller-identity:*)",
      "Bash(aws configure export-credentials:*)",
      "Bash(aws ecs describe-:*)",
      "Bash(aws ecs list-:*)",
      "Bash(aws ecr describe-:*)",
      "Bash(aws ecr list-:*)",
      "Bash(aws ec2 describe-:*)",
      "Bash(aws rds describe-:*)",
      "Bash(aws elbv2 describe-:*)",
      "Bash(aws cloudfront list-:*)",
      "Bash(aws cloudfront get-:*)",
      "Bash(aws iam list-:*)",
      "Bash(aws iam get-:*)",
      "Bash(aws logs describe-:*)",
      "Bash(aws logs get-:*)",
      "Bash(aws s3 ls:*)",
      "Bash(aws s3api list-:*)",
      "Bash(aws s3api head-:*)",
      "Bash(aws s3api get-bucket-:*)",
      "Read(./**/.env.*.example)",
      "Edit(./**/.env.*.example)"
    ],
    "ask": [
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(aws:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./**/*.tfvars)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/credentials)"
    ]
  }
}
